# Git
.git/
.github/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 日志文件
*.log

# 部署脚本（不需要包含在镜像中）
deploy.sh
run*.sh
setup-warp.sh
build-and-push.sh

# 配置模板（部署脚本使用，不是镜像需要的）
*.example

# 例外：gtacore 配置模板（sing-box 格式）烘进镜像，供 run.sh 在服务器端按需提取，
# 从而免去单独上传这些模板文件
!singbox-config.naive.example
!singbox-config.anytls-combo.example
!singbox-config.anyreality-combo.example
!singbox-config.l4.example
!gtagod.conf.example

# 文档
README.md
LICENSE

# 临时文件和备份
*.tmp
*.bak
*.old
*.backup.*
*.rar
*.zip
*.tar.gz

# 本地配置目录
caddy/
singbox/
certificates/

# 环境文件
*.env
config.txt

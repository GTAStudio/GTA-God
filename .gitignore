# =========================================
# GTAGod Git 忽略配置
# =========================================

# =========================================
# 排除所有文件，然后逐个添加需要的
# =========================================
*

# =========================================
# Git 元数据
# =========================================
!.gitignore
!.gitattributes
!.github/
!.github/**

# =========================================
# Docker 构建文件
# =========================================
!Dockerfile
!.dockerignore
!docker-entrypoint.sh
!healthcheck.sh

# =========================================
# 预构建二进制 (gtacore: Rust sing-box 替代，含内嵌 libutls)
# =========================================
!bin/
!bin/gtacore
!bin/gtacore.sha256

# =========================================
# gtagate 网关源码 (Dockerfile rust-builder 阶段构建，排除 target/)
# =========================================
!gateway/
!gateway/Cargo.toml
!gateway/Cargo.lock
!gateway/src/
!gateway/src/**

# =========================================
# 部署脚本和配置模板
# =========================================
!run.sh
!setup-warp.sh
!build-and-push.sh
!gtagod.conf.example
!singbox-config.*.example

# =========================================
# 文档
# =========================================
!README.md
!CLIENT.md
!FRIEND-GUIDE.md

# =========================================
# 敏感文件 (始终忽略)
# =========================================
gtagod.conf
MY-CONFIG.md
caddy/
singbox/
*.log
*.bak

# Deny new files by default.
/*

!/.dockerignore
!/.gitattributes
!/.gitignore
!/Dockerfile
!/certificate-health-lib.sh
!/docker-entrypoint.sh
!/gtacore-watchdog.sh
!/healthcheck.sh

!/.github/
.github/*
!/.github/workflows/
.github/workflows/*
!/.github/workflows/docker-build.yml

!/bin/
bin/*
!/bin/gtacore
!/bin/gtacore.provenance.json
!/bin/gtacore.sha256

!/gateway/
gateway/*
!/gateway/.cargo/
gateway/.cargo/*
!/gateway/.cargo/config.toml
!/gateway/Cargo.lock
!/gateway/Cargo.toml
!/gateway/src/
gateway/src/**
!gateway/src/**/
!gateway/src/*.rs
!gateway/src/**/*.rs

!/tests/
tests/*
!/tests/container-data-path.sh
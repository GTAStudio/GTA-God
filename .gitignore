# =========================================
# GTAGod Git 忽略配置
# =========================================

# =========================================
# 排除所有文件，然后逐个添加需要的
# =========================================
*

# =========================================
# Git 元数据
# =========================================
!.gitignore
!.gitattributes
!.github/
!.github/**

# =========================================
# Docker 构建文件
# =========================================
!Dockerfile
!.dockerignore
!docker-entrypoint.sh
!healthcheck.sh

# =========================================
# gtagate 网关源码 + 预构建二进制（白名单，防新文件被 * 静默忽略；不动 gateway/target）
# =========================================
!bin/
!bin/gtacore
!bin/gtacore.sha256
!gateway/
!gateway/src/
!gateway/src/**
!gateway/Cargo.toml
!gateway/Cargo.lock

# =========================================
# 部署脚本和配置模板
# =========================================
!run.sh
!build-and-push.sh
!gtagod.conf.example
!Caddyfile.*.example
!singbox-config.*.example

# =========================================
# 文档
# =========================================
!README.md
!CLIENT.md
!FRIEND-GUIDE.md

# =========================================
# 敏感文件 (始终忽略)
# =========================================
gtagod.conf
MY-CONFIG.md
caddy/
singbox/
*.log
*.bak

# =========================================
# GTAGod Git 忽略配置
# =========================================

# =========================================
# 排除所有文件，然后逐个添加需要的
# =========================================
*

# =========================================
# Git 元数据
# =========================================
!.gitignore
!.gitattributes
!.github/
!.github/workflows/
!.github/workflows/docker-build.yml

# =========================================
# Docker 构建文件
# =========================================
!Dockerfile
!.dockerignore
!docker-entrypoint.sh
!healthcheck.sh

# =========================================
# gtagate 网关源码 + 预构建二进制（白名单，防新文件被 * 静默忽略；不动 gateway/target）
# =========================================
!bin/
!bin/gtacore
!bin/gtacore.sha256
!gateway/
!gateway/src/
!gateway/src/**
!gateway/Cargo.toml
!gateway/Cargo.lock
!gateway/.cargo/
!gateway/.cargo/config.toml

# =========================================
# 敏感文件 (始终忽略)
# =========================================
gtagod.conf
MY-CONFIG.md
caddy/
singbox/
*.log
*.bak
